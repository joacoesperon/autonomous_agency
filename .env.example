# ========================================================================
# Jess Trading Autonomous Agency — Environment Configuration
# ========================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL variables below with your actual API keys
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Rotate keys every 90 days for security
#
# ========================================================================

# ========================================================================
# CORE LLM API (Required for all agents)
# ========================================================================

# Google Gemini API Key (Free tier: ~20 requests/day)
# Get yours: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================================================
# TELEGRAM (Required — HITL Approval Gateway)
# ========================================================================

# Telegram Bot Token (Get from @BotFather)
# Instructions:
#   1. Open Telegram → Search @BotFather
#   2. Send: /newbot
#   3. Follow prompts to create your bot
#   4. Copy the token provided
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram Chat ID (Where you'll receive notifications)
# To find your Chat ID:
#   1. Send a message to your bot
#   2. Visit: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#   3. Find "chat":{"id":123456789} in the response
TELEGRAM_OWNER_CHAT_ID=123456789

# ========================================================================
# SOCIAL MEDIA APIS (Required for Marketer)
# ========================================================================

# Instagram Graph API Access Token
# Get yours: https://developers.facebook.com/docs/instagram-api
# Requires: Business or Creator account + Facebook Page
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here

# X (Twitter) API Credentials (v2 API with read/write)
# Get yours: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_SECRET=your_x_access_secret_here

# LinkedIn API Access Token (for company page posting)
# Get yours: https://www.linkedin.com/developers/apps
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here

# ========================================================================
# WHOP PLATFORM (Required for Operator)
# ========================================================================

# Whop API Key — READ ONLY (Critical Security)
# Get yours: Whop Dashboard → Settings → API → Create Read-Only Key
# IMPORTANT: Use READ-ONLY key. Write operations require owner manual action.
WHOP_API_KEY_READ=your_whop_readonly_key_here

# Whop Webhook Secret (for sale notifications)
WHOP_WEBHOOK_SECRET=your_whop_webhook_secret_here

# ========================================================================
# STRIPE (Required for Operator)
# ========================================================================

# Stripe API Key — READ ONLY (Critical Security)
# Get yours: Stripe Dashboard → Developers → API Keys → Create Restricted Key
# Permissions: Read-only access to: Charges, PaymentIntents, Disputes
STRIPE_API_KEY_READ=sk_live_readonly_your_key_here

# Stripe Webhook Secret (for payment event notifications)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ========================================================================
# SEARCH & CONTENT GENERATION (Required for Marketer)
# ========================================================================

# Tavily API Key (for web search and trend monitoring)
# Get yours: https://tavily.com (free tier available)
TAVILY_API_KEY=tvly-your_key_here

# Image Generation API (Choose one)
# Option A: Replicate (for Nano Banana Pro or similar)
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# Option B: OpenAI DALL-E (alternative)
# OPENAI_API_KEY=sk-your_openai_key_here

# Option C: Stable Diffusion XL (via Replicate or local)
# (Use Replicate token above)

# ========================================================================
# OPTIONAL: Additional Services
# ========================================================================

# If you add database later (PostgreSQL instead of SQLite)
# DB_PASSWORD=your_secure_postgres_password_here

# For advanced monitoring (Prometheus/Grafana)
# GRAFANA_PASSWORD=your_grafana_admin_password

# For email notifications as backup to Telegram
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password

# ========================================================================
# SYSTEM CONFIGURATION
# ========================================================================

# Environment: development | production
ENVIRONMENT=production

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Heartbeat interval override (in seconds, default 1800 = 30 min)
# HEARTBEAT_INTERVAL=1800

# Agent communication method: telegram | webhook | mqtt
AGENT_COMMUNICATION=telegram

# ========================================================================
# SECURITY NOTES
# ========================================================================
#
# 1. API Key Rotation Schedule:
#    - Rotate all keys every 90 days
#    - Document rotation in: /agent_squad/security/key_rotation_log.md
#
# 2. Least Privilege:
#    - Use READ-ONLY keys wherever possible (Whop, Stripe)
#    - Never store write-capable keys in this file
#
# 3. Backup:
#    - Keep encrypted backup of this file in password manager
#    - Never share via Slack, email, or unencrypted channels
#
# 4. Audit:
#    - Review access logs monthly
#    - Revoke unused API keys immediately
#    - Monitor for unauthorized usage patterns
#
# 5. Compliance:
#    - Ensure API usage complies with each platform's TOS
#    - Delete customer data upon request (GDPR)
#    - Maintain financial records for 7 years (tax compliance)
#
# ========================================================================
# TROUBLESHOOTING
# ========================================================================
#
# If agents fail to start:
# 1. Check this file for missing variables
# 2. Verify API keys are valid (test in Postman/curl)
# 3. Check Docker logs: docker-compose logs <service_name>
# 4. Validate .env is in same directory as docker-compose.yml
#
# If HITL approval not working:
# 1. Verify Telegram bot token is correct
# 2. Verify owner chat ID is correct
# 3. Send a test message to your bot: /start
# 4. Check telegram_gateway logs: docker-compose logs telegram_gateway
#
# ========================================================================
