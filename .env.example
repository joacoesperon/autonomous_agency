# ======================================================================
# CORE LLM KEYS (used by Python skills in this repo)
# ======================================================================
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxx"
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxx"
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXX"
OPENAI_BASE_URL="http://127.0.0.1:11434/v1"
OPENAI_MODEL="llama3.3:latest"
OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"
OLLAMA_API_KEY="ollama"

# Optional: local OpenAI-compatible endpoint (Ollama, vLLM, etc.)
# If set, shared/llm_provider.py will route OpenAI calls to this base URL.
# For Ollama, OPENAI_API_KEY can be "ollama".
# OPENAI_BASE_URL="http://127.0.0.1:11434/v1"
# OPENAI_MODEL="llama3.3:latest"
# OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"
# OLLAMA_API_KEY="ollama"

# ======================================================================
# TELEGRAM HITL (approval bot used by sub-agents in this repo)
# ======================================================================
# Single bot for approvals by default.
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklmNOPqrsTUVwxyZ"
TELEGRAM_OWNER_CHAT_ID="987654321"

# Optional: if you route multiple Telegram accounts in OpenClaw itself,
# define those in ~/.openclaw/openclaw.json under channels.telegram.accounts.
# These placeholders are for your own config convenience only.
# TELEGRAM_BOT_TOKEN_MAIN="123456:AAA..."
# TELEGRAM_BOT_TOKEN_MARKETER="123456:BBB..."
# TELEGRAM_BOT_TOKEN_SUPPORT="123456:CCC..."
# TELEGRAM_BOT_TOKEN_OPERATOR="123456:DDD..."

