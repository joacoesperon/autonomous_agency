# ==========================================
# LOCAL LLM (OLLAMA) - OpenAI Compatibility Trick
# ==========================================
# If you want to use Ollama inside your Python skills locally for FREE, 
# you MUST set OPENAI_API_KEY to "ollama", AND uncomment this base URL. 
# Your skills will think they are talking to OpenAI, but they will send 
# requests to your local Ollama server.
#
# OPENAI_API_KEY="ollama"
# OPENAI_BASE_URL="http://127.0.0.1:11434/v1"
# OPENAI_MODEL="llama3.3:latest" # Or whatever model you pulled in Ollama
